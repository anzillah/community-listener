# ── Help Scout ──────────────────────────────────────────────────────────────
# Create an OAuth2 app at: https://secure.helpscout.net/apps/oauth2/
# Grant type: client_credentials
HELPSCOUT_CLIENT_ID=your_client_id
HELPSCOUT_CLIENT_SECRET=your_client_secret

# ID of the "Community" mailbox (visible in Help Scout → Mailbox Settings URL)
HELPSCOUT_MAILBOX_ID=123456

# ── Discord ──────────────────────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications → Bot
# REQUIRED privileged intent: MESSAGE CONTENT (toggle ON in the Dev Portal)
DISCORD_TOKEN=your_discord_bot_token

# One or more channel IDs to monitor — separate multiple IDs with commas.
# Right-click each channel → Copy Channel ID (Developer Mode must be on).
# Example with one channel:  DISCORD_CHANNEL_IDS=1234567890123456789
# Example with three:        DISCORD_CHANNEL_IDS=111111111,222222222,333333333
DISCORD_CHANNEL_IDS=111111111,222222222

# ── App Store IDs ────────────────────────────────────────────────────────────
# iOS: comma-separated numeric App IDs from the App Store URL.
# Find it in the URL: apps.apple.com/app/readwise/id1288723640
# One app:  IOS_APP_IDS=1288723640
# Two apps: IOS_APP_IDS=1288723640,1341630099
IOS_APP_IDS=1476885528,1567599761

# Android: comma-separated package names from the Play Store URL.
# Find it in the URL: play.google.com/store/apps/details?id=com.readwise.readwise
# One app:  ANDROID_APP_IDS=com.readwise.readwise
# Two apps: ANDROID_APP_IDS=com.readwise.readwise,com.readwise.reader
ANDROID_APP_IDS=com.example.app1,com.example.app2

# ── Reddit (no credentials required) ────────────────────────────────────────
# Uses Reddit's public JSON API — no app or OAuth needed.
# One conversation per thread — OP body as the first message, comments as replies.
# Optional: comma-separated extra thread IDs to always monitor (e.g. pinned posts)
# REDDIT_THREAD_IDS=abc123,def456

# ── Bluesky (optional) ───────────────────────────────────────────────────────
# Handle to search mentions for. No auth required (public search API).
# Leave blank to disable this collector.
BSKY_HANDLE=yourapp.bsky.social

# ── GitHub (optional) ────────────────────────────────────────────────────────
# Personal access token — required when monitoring many repos.
# Without it: 60 req/hr (hits the cap fast). With it: 5000 req/hr.
# Create at: https://github.com/settings/tokens
# (no scope needed for public repos; add "repo" scope for private repos)
GITHUB_TOKEN=github_pat_your_token_here

# Specific repos to monitor, comma-separated (owner/repo format).
GITHUB_REPOS=owner/repo1,owner/repo2

# Optional: monitor every public repo in an org instead (or in addition).
# Uncomment only if you want the full org sweep.
# GITHUB_ORG=yourorg

# ── Anthropic (LLM summaries) ────────────────────────────────────────────────
# Powers one-sentence "what they want/need" summaries in every ticket subject
# and Summary metadata row.  Leave blank to fall back to plain-text excerpts.
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-your_key_here

# ── Optional overrides ───────────────────────────────────────────────────────
# DB_PATH=community_listener.db
# POLL_INTERVAL_MINUTES=10
# REDDIT_SUBREDDIT=readwise
# REDDIT_NEW_POSTS_LIMIT=25
